#!/usr/bin/env ruby
require 'webrick'
port = ENV.fetch('PORT', '3000').to_i
server = WEBrick::HTTPServer.new(BindAddress: '0.0.0.0', Port: port, AccessLog: [], Logger: WEBrick::Log.new($stderr, WEBrick::Log::WARN))
trap('TERM') { server.shutdown }
server.mount_proc('/') { |_req, res| res.status = 200; res['Content-Type'] = 'text/plain'; res.body = 'axhub rails ok' }
server.start
